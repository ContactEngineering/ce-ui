{
    "compilerOptions": {
        "target": "es2020",
        "module": "esnext",
        "moduleResolution": "bundler",
        "lib": ["es2020", "dom", "dom.iterable"],
        "allowJs": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "noEmit": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["frontend/*"]
        }
    },
    "include": ["frontend/**/*.ts", "frontend/**/*.vue"],
    "exclude": ["node_modules"]
}
